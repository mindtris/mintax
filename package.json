  },
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-next.cjs",
    "dev": "next dev --turbo -p 8080",
    "build": "node scripts/patch-next.cjs && prisma generate --schema=lib/prisma/schema.prisma && prisma db push --schema=lib/prisma/schema.prisma && next build",
    "start": "prisma migrate deploy --schema=lib/prisma/schema.prisma && next start",
    "db:generate": "prisma generate --schema=lib/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=lib/prisma/schema.prisma",
    "db:push": "prisma db push --schema=lib/prisma/schema.prisma",
    "lint": "next lint"
  },
  "dependencies": {
