# ═══════════════════════════════════════════════════════════════════════════
# MINTAX — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values. .env is gitignored.


# ═══════════════════════════════════════════════════════════════════════════
# CORE
# ═══════════════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=8080
BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:8080
SELF_HOSTED_MODE=true


# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Required. Use Neon, Supabase, local Postgres, or any Postgres provider.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mintax
# DATABASE_URL_UNPOOLED=       # Optional: direct connection for migrations


# ─── Storage ────────────────────────────────────────────────────────────────
# Provider: "local" | "s3" | "vercel-blob"
STORAGE_PROVIDER=local
UPLOAD_PATH=./data/uploads

# S3 / R2 / MinIO / Backblaze (required when STORAGE_PROVIDER=s3)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=                 # R2: https://{acct}.r2.cloudflarestorage.com
# S3_PREFIX=uploads/
# S3_FORCE_PATH_STYLE=true

# Vercel Blob (required when STORAGE_PROVIDER=vercel-blob)
# BLOB_READ_WRITE_TOKEN is auto-set by Vercel when you create a Blob store
# BLOB_PREFIX=mintax


# ─── Authentication ─────────────────────────────────────────────────────────
# Required. Generate a random string (min 16 chars).
BETTER_AUTH_SECRET=please-change-this-to-a-long-random-string
# DISABLE_SIGNUP=false         # Prevent new signups
# SELF_HOSTED_PIN=             # Protect self-hosted instance with a PIN


# ─── Cron Jobs ──────────────────────────────────────────────────────────────
# Set any random string. Cron endpoints require: Authorization: Bearer <secret>
CRON_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# AI PROVIDERS (LLM)
# ═══════════════════════════════════════════════════════════════════════════
# Used for: invoice analysis, content generation, job descriptions, etc.
# At least one recommended. Can also be configured via UI at /settings?tab=llm

OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=

GOOGLE_MODEL_NAME=gemini-2.5-flash
GOOGLE_API_KEY=

MISTRAL_MODEL_NAME=mistral-medium-latest
MISTRAL_API_KEY=

# Local Ollama / OpenAI-compatible endpoint (offline AI)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL_NAME=
OPENAI_COMPATIBLE_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# EMAIL
# ═══════════════════════════════════════════════════════════════════════════
# Used for: invoice emails, reminders, OTP, newsletters, transactional mail

# MAIL_DRIVER: "resend" or "smtp"
MAIL_DRIVER=smtp
MAIL_SENDER_NAME=
MAIL_SENDER_EMAIL=
MAIL_REPLY_TO=

# SMTP (used when MAIL_DRIVER=smtp)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=465
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_ENCRYPTION=ssl

# Resend (used when MAIL_DRIVER=resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_AUDIENCE_ID=


# ═══════════════════════════════════════════════════════════════════════════
# PAYMENTS (Stripe)
# ═══════════════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# BANK CONNECTIONS (Plaid) — US / CA / GB
# ═══════════════════════════════════════════════════════════════════════════
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_SECRET=
# 32-byte key, base64 encoded: openssl rand -base64 32
PLAID_ENCRYPTION_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# ENGAGE — Social Media Providers (OAuth)
# ═══════════════════════════════════════════════════════════════════════════
# All optional — only configure providers you want to enable.
# Redirect URI for all: {BASE_URL}/api/social/callback/{provider}

# ─── Meta (Facebook, Instagram, Threads) ────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── X (Twitter) ────────────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── LinkedIn ───────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Google (YouTube, Google My Business) ──────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── TikTok ─────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Pinterest ──────────────────────────────────────────────────────────────
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# ─── Reddit ─────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Dribbble ───────────────────────────────────────────────────────────────
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

# ─── Twitch ─────────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# HIRE — Recruitment & Job Postings
# ═══════════════════════════════════════════════════════════════════════════
# Used for: bench submissions, career portals, candidate outreach
# Job application public URL pattern: {NEXT_PUBLIC_APP_URL}/hire/apply/{jobId}
# Microsoft Graph below is used by bench submit-to-client email feature.


# ═══════════════════════════════════════════════════════════════════════════
# APPS — Microsoft Graph (Outlook integration)
# ═══════════════════════════════════════════════════════════════════════════
# Used by: /apps/outlook, bench submit-to-client email sending
# Register app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=


# ═══════════════════════════════════════════════════════════════════════════
# BUG REPORTING (GitHub Issues)
# ═══════════════════════════════════════════════════════════════════════════
# Used by: /report-bug to create GitHub issues on user feedback
GITHUB_TOKEN=
GITHUB_REPO=mindtris/mintax


# ═══════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════

# ─── Sentry (error tracking) ────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Telemetry ──────────────────────────────────────────────────────────────
TELEMETRY_DISABLED=false
# TELEMETRY_ENDPOINT=https://api.mindtris.com/telemetry
