PORT=7331
UPLOAD_PATH="./data/uploads"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mintax"

# Storage Provider: "local" (default) or "s3" (works with AWS S3, Cloudflare R2, MinIO, Backblaze B2)
STORAGE_PROVIDER="local"

# S3 Configuration (required when STORAGE_PROVIDER="s3")
# S3_BUCKET=""
# S3_REGION="us-east-1"
# S3_ENDPOINT=""                   # Custom endpoint for R2/MinIO (e.g. https://acct.r2.cloudflarestorage.com)
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PREFIX=""                     # Optional key prefix (e.g. "uploads/")
# S3_FORCE_PATH_STYLE="true"      # Set to "false" for AWS S3 virtual-hosted style

# AI Providers (configure in UI or set here)
OPENAI_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY=""  # "sk-..."

GOOGLE_MODEL_NAME="gemini-2.5-flash"
GOOGLE_API_KEY=""

MISTRAL_MODEL_NAME="mistral-medium-latest"
MISTRAL_API_KEY=""

# Auth Config
BETTER_AUTH_SECRET="random-secret-key"  # please use any long random string here (min 16 chars)
# SELF_HOSTED_PIN="1234"  # Optional: protect self-hosted instance with a PIN

# Stripe Configuration (optional)
STRIPE_SECRET_KEY=""  # "sk_live_..." or "sk_test_..."
STRIPE_WEBHOOK_SECRET=""  # "whsec_..."

# Cron Secret (protects the /api/reminders/process endpoint)
# CRON_SECRET=""  # Set any random string; call with: Authorization: Bearer <secret>

# Resend Configuration (optional, for sending emails)
RESEND_API_KEY=""  # "re_..."
RESEND_AUDIENCE_ID=""  # "aud_..."
RESEND_FROM_EMAIL="Mintax <noreply@mintax.app>"

# Social Media Providers (OAuth)
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
GOOGLE_OAUTH_CLIENT_ID=""      # For YouTube & Google My Business
GOOGLE_OAUTH_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
DRIBBBLE_CLIENT_ID=""
DRIBBBLE_CLIENT_SECRET=""
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# Microsoft Graph Integration
NEXT_PUBLIC_MICROSOFT_CLIENT_ID="" # "00000000-0000-0000-0000-000000000000"
