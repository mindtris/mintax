# cal.diy environment — copy to .env and fill every value.
# Do not commit .env. All secrets below must be generated fresh per environment.

# ──────────────────────────────────────────────────────────────
# Image + database
# ──────────────────────────────────────────────────────────────
# Pin to a specific release tag before production. See tag list on Docker Hub:
# https://hub.docker.com/r/calcom/cal.diy/tags
# For ARM hosts, append "-arm" (e.g. v5.6.19-arm).
CAL_IMAGE_TAG=latest

# Password for the bundled cal-postgres container.
# Generate: openssl rand -base64 32
CAL_DB_PASSWORD=

# ──────────────────────────────────────────────────────────────
# Public URLs (must match the domain you serve cal.diy from)
# ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://cal.example.com
NEXT_PUBLIC_WEBAPP_URL=https://cal.example.com
NEXT_PUBLIC_API_V2_URL=https://cal.example.com/api/v2

# ──────────────────────────────────────────────────────────────
# Cryptographic secrets — all must be unique, never reused
# ──────────────────────────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET=

# Exactly 32 characters. openssl rand -hex 16
CALENDSO_ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────────
# AGPL licence acknowledgement — required by cal.diy
# ──────────────────────────────────────────────────────────────
LICENSE_CONSENT=agree

# ──────────────────────────────────────────────────────────────
# Transactional email (bookings, reminders, invites)
# ──────────────────────────────────────────────────────────────
EMAIL_FROM=bookings@example.com
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=

# ──────────────────────────────────────────────────────────────
# Webhook signing — this is the secret cal.diy uses to sign
# outgoing webhook payloads. Mintax verifies HMAC-SHA256 against
# this value. Keep it in sync with CALCOM_WEBHOOK_SECRET in mintax.
# openssl rand -hex 32
# ──────────────────────────────────────────────────────────────
CALCOM_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
# Admin / v2 API key — used by mintax to call cal.diy server-side
# (team provisioning, event-type seeding). Generate inside cal.diy:
# Settings → Developer → API Keys after first boot.
# Leave blank on first deploy; fill in after you create the key.
# ──────────────────────────────────────────────────────────────
CALCOM_ADMIN_API_KEY=

# ──────────────────────────────────────────────────────────────
# Optional — Google Calendar connector (users sync their own calendars)
# Create OAuth client at https://console.cloud.google.com
# ──────────────────────────────────────────────────────────────
GOOGLE_API_CREDENTIALS=

# ──────────────────────────────────────────────────────────────
# Optional — Microsoft 365 / Outlook connector
# ──────────────────────────────────────────────────────────────
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────
# Optional — Zoom connector (auto-generate video links)
# ──────────────────────────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
